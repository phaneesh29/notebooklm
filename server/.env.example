PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/notebooklm
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here
REDIS_URL=redis://localhost:6379
DOCUMENT_INGESTION_QUEUE_NAME=document-ingestion
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=notebooklm-documents

# Chat settings
CHAT_MODEL=gemini-3.1-flash-lite-preview
CHAT_AGENT_NAME=chatAssistant
CHAT_APP_NAME=notebooklm-chat
CHAT_HISTORY_TURN_LIMIT=5
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Vector DB settings
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=document_chunks
QDRANT_VECTOR_SIZE=3072
